{
	"name": "vite-plugin-keep-console",
	"version": "1.1.1",
	"packageManager": "pnpm@10.11.0",
	"description": "Production console policy for Vite: remove, keep, report, or fail builds on console calls with Babel/OXC backends.",
	"keywords": [
		"vite",
		"vite-plugin",
		"console",
		"console-policy",
		"remove-console",
		"strip-console",
		"build-tool",
		"production",
		"typescript",
		"javascript",
		"babel",
		"oxc",
		"logging",
		"ci"
	],
	"homepage": "https://github.com/biubiukam/vite-plugin-keep-console",
	"bugs": {
		"url": "https://github.com/biubiukam/vite-plugin-keep-console/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/biubiukam/vite-plugin-keep-console"
	},
	"license": "MIT",
	"author": "biubiukam",
	"exports": {
		".": {
			"types": "./dist/lib/index.d.ts",
			"import": "./dist/es/index.mjs",
			"require": "./dist/lib/index.js"
		}
	},
	"main": "dist/lib/index.js",
	"module": "dist/es/index.mjs",
	"types": "dist/lib/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "tsup",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"prepare": "husky",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@babel/generator": "^7.27.1",
		"@babel/parser": "^7.27.2",
		"@babel/traverse": "^7.27.1",
		"@babel/types": "^7.27.1",
		"magic-string": "^0.30.21"
	},
	"optionalDependencies": {
		"oxc-parser": "^0.137.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@vitest/coverage-v8": "^3.1.3",
		"eslint": "^9.39.4",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.1.0",
		"tsup": "^8.5.0",
		"typescript": "^7.0.2",
		"typescript-eslint": "^8.62.0",
		"vite": "^8.1.5",
		"vitest": "^3.1.3"
	},
	"peerDependencies": {
		"vite": "^3.1.0 || ^4.0.0-0 || ^5.0.0-0 || ^6.0.0-0 || ^7.0.0-0 || ^8.0.0-0"
	},
	"engines": {
		"node": ">=v14.21.3"
	},
	"lint-staged": {
		"*.{ts,tsx,mjs,js}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md,yml,yaml,css,less}": [
			"prettier --write"
		]
	}
}
